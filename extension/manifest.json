{
  "manifest_version": 3,
  "name": "Glance",
  "version": "0.1.0",
  "description": "AI page intelligence for the tab you are reading, powered by your Gemini API key.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus"],
  "host_permissions": ["<all_urls>", "https://generativelanguage.googleapis.com/*"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open Glance",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/glance-16.png",
      "48": "icons/glance-48.png",
      "128": "icons/glance-128.png"
    }
  },
  "icons": {
    "16": "icons/glance-16.png",
    "48": "icons/glance-48.png",
    "128": "icons/glance-128.png"
  },
  "options_page": "src/options/index.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  },
  "commands": {
    "toggle_sidebar": {
      "suggested_key": {
        "default": "Alt+P"
      },
      "description": "Open or refresh the Glance sidebar"
    },
    "explain_selection": {
      "suggested_key": {
        "default": "Alt+E"
      },
      "description": "Explain the current text selection with Glance"
    }
  }
}
